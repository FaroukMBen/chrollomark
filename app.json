{
  "expo": {
    "name": "chrollomark",
    "slug": "chrollomark",
    "version": "3.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-v2.png",
    "scheme": "chrollomark",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B14",
        "foregroundImage": "./assets/images/app-icon-v2.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.faroukmben.chrollomark",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "REQUEST_INSTALL_PACKAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-v2.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0B0B14",
          "dark": {
            "backgroundColor": "#0B0B14"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "525372f4-0bbc-4f73-9693-6e5f468d1584"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/525372f4-0bbc-4f73-9693-6e5f468d1584"
    }
  }
}
